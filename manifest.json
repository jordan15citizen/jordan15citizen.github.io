{
  "name": "system-tools",
  "version": "2.6",
  "maintainer": "jordan15citizen",
  "control": {
    "Architecture": "aarch64",
    "Description": "The Ultimate System Suite (Auto-Config)",
    "Depends": "termux-api, curl, dnsutils",
    "Conflicts": "sysinfo",
    "Replaces": "sysinfo"
  },
  "files": {
    "./sysinfo": "bin/sysinfo",
    "./sys-stat": "bin/sys-stat",
    "./sys-clean": "bin/sys-clean",
    "./sys-net": "bin/sys-net",
    "./sys-alias": "bin/sys-alias",
    "./sys-weather": "bin/sys-weather"
  },
  "scripts": {
    "postinst": "./postinst"
  }
}
