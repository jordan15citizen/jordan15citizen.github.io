#!/data/data/com.termux/files/usr/bin/sh
set -e

echo "[*] Starting system-tools 0.43.5 installation..."

# 1. Cleanup old messy configs and ghost keys
rm -f "$PREFIX/etc/apt/trusted.gpg.d/jordan15citizen.gpg"
rm -f "$PREFIX/etc/apt/trusted.gpg.d/jordan.gpg"
rm -f "$PREFIX/etc/apt/trusted.gpg.d/jordan.gpg~"
rm -f "$PREFIX/etc/apt/sources.list.d/system-tools.list"

# 2. Import GPG Key as a clean Binary (The "Nohajc" fix)
# This prevents the 'unsupported filetype' warnings
curl -sL "https://jordan15citizen.github.io/termux/jordan_pub.gpg" | gpg --dearmor -o "$PREFIX/etc/apt/trusted.gpg.d/jordan15citizen.gpg"

# 3. Add the Repository Source with the clean single-slash syntax
echo "deb https://jordan15citizen.github.io/termux /" > "$PREFIX/etc/apt/sources.list.d/system-tools.list"

# 4. Sync and Install
echo "[*] Updating package lists..."
pkg update -y

echo "[*] Installing system-tools..."
pkg install -y system-tools

# 5. Final Check
if command -v system-tools >/dev/null 2>&1; then
    echo "----------------------------------------"
    echo " DONE: system-tools is now active."
    echo " Run 'system-tools' to begin."
    echo "----------------------------------------"
else
    echo "[!] Installation failed. Check your internet connection."
    exit 1
fi
