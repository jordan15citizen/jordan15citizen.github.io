#!/data/data/com.termux/files/usr/bin/bash
set -e
G='\033[0;92m'
NC='\033[0m'
msg() { printf "${G}==>${NC} $*\n"; }

# 1. Prep Workspace
msg "Cleaning old builds..."
rm -f *.deb termux/*.deb

# 2. Setup permissions
chmod +x src/quick-flash
chmod +x src/system-tools
chmod 600 lib/libsystem-tools.so
chmod +x postinst
# 3. Build and Move
msg "Building package..."
termux-create-package manifest.json
mv *.deb termux/

# 4. Create Metadata Config
cat <<EOF > apt.conf
APT::FTPArchive::Release::Origin "jordan15citizen";
APT::FTPArchive::Release::Label "jordan15citizen";
APT::FTPArchive::Release::Suite "termux";
APT::FTPArchive::Release::Codename "termux";
APT::FTPArchive::Release::Architectures "all aarch64";
APT::FTPArchive::Release::Components "main";
EOF

# 5. Indexing (Creating both raw and compressed)
msg "Updating Repo Index..."
dpkg-scanpackages termux /dev/null > termux/Packages
gzip -9c termux/Packages > termux/Packages.gz


# 6.Signing with Metadata
cd termux
msg "Generating Release with Metadata..."
apt-ftparchive -c ../apt.conf release . > Release

msg "Signing (No Passphrase Mode)..."
# Using loopback to ensure it never hangs on a prompt
gpg --batch --yes --pinentry-mode loopback --passphrase "" --clearsign -o InRelease Release
gpg --batch --yes --pinentry-mode loopback --passphrase "" -abs -o Release.gpg Release

# 7. Push to GitHub
msg "Pushing to GitHub..."
cd ..
git add .
git commit -m "$1"
git push origin main

msg "${G}Finished building and finalising.${NC}"
curl -s https://raw.githubusercontent.com/nohajc/termux-adb/master/install.sh | bash
