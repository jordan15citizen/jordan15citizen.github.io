#!/data/data/com.termux/files/usr/bin/bash
set -e
G='\033[0;92m'
NC='\033[0m'
msg() { printf "${G}==>${NC} $*\n"; }

# 1. Prep Workspace
msg "Cleaning old builds..."
rm -f *.deb termux/*.deb

# 2. Setup permissions
chmod +x src/quick-flash
chmod +x src/system-tools
chmod 600 lib/libsystem-tools.so
chmod +x postinst

# 3. Build and Move
msg "Building package..."
termux-create-package manifest.json
mv *.deb termux/

# ... (Step 4: Create apt.conf) ...

# 5. Indexing (The Fix: Jump in, scan, jump out)
msg "Updating Repo Index..."
cd termux
# By being INSIDE, the filename in 'Packages' becomes './system-tools_0.44.1_all.deb'
dpkg-scanpackages . /dev/null > Packages
gzip -9c Packages > Packages.gz
cd .. # Jump back to root so the rest of the script works

# 6. Signing (Jump in again or stay in root and point)
cd termux
msg "Generating Release with Metadata..."
apt-ftparchive -c ../apt.conf release . > Release

msg "Signing (No Passphrase Mode)..."
gpg --batch --yes --pinentry-mode loopback --passphrase "" --clearsign -o InRelease Release
gpg --batch --yes --pinentry-mode loopback --passphrase "" -abs -o Release.gpg Release
cd .. # Back to root for Git


# 7. Push to GitHub
msg "Pushing to GitHub..."
git add .
git commit -m "$1"
git push origin main

msg "${G}Finished building and finalising.${NC}"
