#!/bin/bash
echo "--- [ System Status ] ---"

# Use Termux API to get battery data in JSON, then parse it
BATT_INFO=$(termux-battery-status)

echo "$BATT_INFO" | grep "percentage" | sed 's/[",]//g' | awk '{print "Battery: " $2 "%"}'
echo "$BATT_INFO" | grep "status" | sed 's/[",]//g' | awk '{print "Status: " $2}'
echo "$BATT_INFO" | grep "temperature" | sed 's/[",]//g' | awk '{print "Temp: " $2 "°C"}'

echo "------------------------"
